---
import { skills } from '../data/site';
import Folio from './Folio.astro';

// Loadout presentation metadata. The skill LIST stays in site.ts (single source);
// these maps add the game-flavor (rarity weight + monogram) used to render slots.
// The bar for each tier, so the ladder means something and stays defensible:
//   LEGENDARY (5) — built the thing from scratch, or it is the differentiator a
//                   reviewer would remember. Backed by a shipped artefact.
//   EPIC (4)      — used it hard across more than one project, past tutorial depth.
//   RARE (3)      — real but narrow: one project, one component, or a single use.
const WEIGHTS: Record<string, number> = {
  // Languages — C rebuilt Git, Rust built a distributed KV store from std alone
  C: 5, Python: 5, TypeScript: 5, Rust: 5, JavaScript: 4, HTML: 4, CSS: 4, SQL: 3, WGSL: 4,
  // ML / AI — PyTorch and NumPy off hand-rolled message passing and the 96s→2s rewrite
  PyTorch: 5, NumPy: 5, 'scikit-learn': 4, Pandas: 4, 'Deep Learning': 4,
  'Graph Neural Networks': 4, 'Synthetic Data': 4, SciPy: 3, Matplotlib: 3, Quantization: 3, vLLM: 3,
  // Interpretability / LLM — the most differentiated work on the board
  'Mechanistic Interpretability': 5, TransformerLens: 5, RAG: 5, 'LLM Evaluation': 5,
  'Activation Patching': 4, 'Linear Probing': 4, 'HuggingFace Transformers': 4,
  'Failure Taxonomy': 4, 'Tool Calling': 3, 'Structured Outputs': 3,
  // Research / Methods — the conformal + causal spine of the DRAGNET paper, and the
  // control that killed a positive finding, which is the rarest thing here
  'Conformal Prediction': 5, 'Causal Inference': 5, 'Experimental Design': 5,
  'Statistical Inference': 4, 'Benchmark Design': 4, LaTeX: 4, 'Scientific Writing': 3,
  // Web / Frontend
  React: 5, 'Next.js': 4, Astro: 4, Vite: 4, 'Tailwind CSS': 4, PWA: 4,
  'IndexedDB / Dexie.js': 4, 'React Router': 3, 'Web Workers': 3, Leaflet: 3,
  // Graphics / Realtime — WebGPU trained a net on hand-written WGSL kernels
  WebGPU: 5, WebRTC: 4, 'SVG / Data Viz': 4, 'Framer Motion': 4, Canvas: 3, GSAP: 3, 'Web Speech API': 3,
  // Backend / Data
  FastAPI: 4, SQLAlchemy: 4, PostgreSQL: 4, 'Node.js': 4, 'REST APIs': 4, 'OpenAI Realtime API': 4,
  Pydantic: 3, MongoDB: 3, Express: 3, 'JWT Auth': 3, 'Rate Limiting': 3, Streamlit: 3,
  // Tools / Systems — pytest at 5: 96 + 135 tests, red-green, caught real bugs;
  // Distributed Systems at 5 off Tessera's LSM + Raft + deterministic simulator
  pytest: 5, 'Distributed Systems': 5, Git: 4, 'GitHub Actions': 4, Docker: 4, Linux: 4,
  Vitest: 4, Playwright: 4, 'Hugging Face Hub': 4, Vercel: 3, 'Kaggle GPU': 3, 'OpenRouter API': 3,
};

const ABBR: Record<string, string> = {
  C: 'C', Python: 'PY', TypeScript: 'TS', JavaScript: 'JS', Rust: 'RS', SQL: 'SQL',
  HTML: 'HTM', CSS: 'CSS', WGSL: 'WGS',
  PyTorch: 'TRC', NumPy: 'NPY', 'scikit-learn': 'SKL', Pandas: 'PDS', SciPy: 'SCI',
  Matplotlib: 'MPL', 'Deep Learning': 'DL', 'Graph Neural Networks': 'GNN',
  'Mechanistic Interpretability': 'MECH', TransformerLens: 'TLN', 'Activation Patching': 'PCH',
  'Linear Probing': 'PRB', 'HuggingFace Transformers': 'HFT', Quantization: 'QNT', vLLM: 'VLM',
  'LLM Evaluation': 'EVAL', RAG: 'RAG', 'Failure Taxonomy': 'FTX', 'Synthetic Data': 'SYN',
  'Tool Calling': 'TOOL', 'Structured Outputs': 'STR',
  'Conformal Prediction': 'CNF', 'Causal Inference': 'CSL', 'Experimental Design': 'EXD',
  'Statistical Inference': 'STA', 'Benchmark Design': 'BCH', 'Scientific Writing': 'SCW', LaTeX: 'TEX',
  React: 'RCT', 'Next.js': 'NXT', 'React Router': 'RTR', Astro: 'AST', Vite: 'VITE',
  'Tailwind CSS': 'TWD', 'Framer Motion': 'FRM', GSAP: 'GSP', 'SVG / Data Viz': 'SVG',
  Canvas: 'CNV', WebGPU: 'WGP', WebRTC: 'RTC', 'Web Speech API': 'SPE', 'Web Workers': 'WRK',
  PWA: 'PWA', 'IndexedDB / Dexie.js': 'IDB', Leaflet: 'LFL',
  FastAPI: 'API', Pydantic: 'PYD', SQLAlchemy: 'SQA', PostgreSQL: 'PG', MongoDB: 'MDB',
  'Node.js': 'NODE', Express: 'EXP', 'REST APIs': 'REST', 'JWT Auth': 'JWT',
  'OpenAI Realtime API': 'RT', 'Rate Limiting': 'RL', Streamlit: 'STL',
  Git: 'GIT', 'GitHub Actions': 'GHA', Docker: 'DKR', Linux: 'LNX',
  'Distributed Systems': 'DIST', pytest: 'PYT',
  Vitest: 'VIT', Playwright: 'PWR', Vercel: 'VRC', 'Hugging Face Hub': 'HUB',
  'Kaggle GPU': 'KGL', 'OpenRouter API': 'ORT',
};

const wOf = (n: string) => WEIGHTS[n] ?? 4;
const abbrOf = (n: string) => ABBR[n] ?? n.slice(0, 3).toUpperCase();
const rarityClass = (w: number) => (w >= 5 ? 'legendary' : w >= 4 ? 'epic' : 'rare');
const rarityShort = (w: number) => (w >= 5 ? 'LEG' : w >= 4 ? 'EPI' : 'RAR');
const rarityWord = (w: number) => (w >= 5 ? 'Legendary' : w >= 4 ? 'Epic' : 'Rare');
const totalSlots = skills.reduce((a, g) => a + g.items.length, 0);
---

<section class="section" id="stack">
  <!-- the act break: the loadout works the night shift -->
  <div class="night-band" aria-hidden="true">
    <span>NIGHT SHIFT</span>
    <span class="nb-dim">&middot;</span>
    <span class="nb-lime" id="night-time">&mdash; IST</span>
    <span class="nb-dim">&middot;</span>
    <span>THE PRESS SLEEPS, THE BUILD DOESN&rsquo;T</span>
  </div>
  <div class="section-head">
    <Folio page="P.5" desk="THE GAMES PAGE" tone="ink" />
    <span class="kicker">stack</span>
    <h2 class="h2 ld-head" id="ld-head" aria-label="Built, not bookmarked">
      <span class="hl"><span class="hl-in">Built,&nbsp;not</span></span>
      <span class="hl"><span class="hl-in"><span class="bk">bookmarked</span></span></span>
    </h2>
  </div>

  <div class="legend" aria-hidden="true">
    <span class="lg-lab">RARITY:</span>
    <span class="key"><span class="swatch"></span> <b>RARE</b> &middot; lvl 3</span>
    <span class="key"><span class="swatch epic"></span> <b>EPIC</b> &middot; lvl 4</span>
    <span class="key"><span class="swatch leg"></span> <b>LEGENDARY</b> &middot; lvl 5</span>
    <span class="leg-note">equipped &middot; <b>{totalSlots}</b> slots / {skills.length} classes</span>
  </div>

  <div class="loadout" id="loadout">
    {
      skills.map((g) => (
        <section class="panel" data-fade>
          <div class="panel-head">
            <div class="class-tag"><span class="pre">CLASS:</span><span class="class-name">{g.group}</span></div>
            <div class="slots-of">{String(g.items.length).padStart(2, '0')} SLOTS</div>
          </div>
          <div class="grid-slots">
            {g.items.map((name) => {
              const w = wOf(name);
              return (
                <button
                  type="button"
                  class={`slot ${rarityClass(w)}`}
                  data-name={name}
                  data-weight={w}
                  data-group={g.group}
                  aria-label={`${name} — ${rarityWord(w)} tier, level ${w} of 5`}
                >
                  <span class="mono" aria-hidden="true">{abbrOf(name)}</span>
                  <span class="slot-top"><span class="name decode" data-text={name.toUpperCase()}>{name.toUpperCase()}</span></span>
                  <span class="meta">
                    <span class="rar">{rarityShort(w)}</span>
                    <span class="pips">{Array.from({ length: 5 }).map((_, d) => (<i class={d >= w ? 'off' : undefined}></i>))}</span>
                  </span>
                </button>
              );
            })}
          </div>
        </section>
      ))
    }
  </div>

  <div class="readout" id="sk-readout">
    <span class="prompt">&gt;</span>
    <!-- not a live region: it rewrites on every hover, which spams screen readers;
         each slot already carries the same info in its aria-label -->
    <span class="log" id="logText">idle — hover or tap a slot to inspect equipped gear</span>
    <span class="blink" aria-hidden="true"></span>
  </div>

  <div class="cat" id="cat" aria-hidden="true">
    <div class="bubble" id="catSay">&gt; companion online. show me the build.</div>
    <svg class="kitty" viewBox="0 0 96 80" fill="none" aria-hidden="true">
      <path class="tail" d="M70 58 C 88 56, 90 40, 80 34" stroke="#0a0a0a" stroke-width="5" stroke-linecap="round" />
      <path d="M22 40 L22 70 L70 70 L70 40 Z" fill="#0a0a0a" />
      <path d="M24 18 L24 46 L68 46 L68 18 L58 28 L34 28 Z" fill="#0a0a0a" />
      <path d="M24 18 L24 6 L36 26 Z" fill="#0a0a0a" />
      <path d="M68 18 L68 6 L56 26 Z" fill="#0a0a0a" />
      <rect x="32" y="32" width="9" height="3.4" fill="#ffffff" />
      <rect x="51" y="32" width="9" height="3.4" fill="#ffffff" />
      <rect x="44.5" y="38" width="3" height="3" fill="#ffffff" />
    </svg>
  </div>

  <div class="ld-card" id="ld-card" role="tooltip" aria-hidden="true"></div>
</section>

<script>
  // Loadout interaction: hover/focus a slot for its item card + set-bonus lighting;
  // click to pin (touch/mobile); names shrink-to-fit so tiles stay uniform.
  // Slots are server-rendered from site.ts; this only wires up behavior.

  const RELATED: Record<string, string[]> = {
    C: ['WGSL', 'Linux', 'Git'],
    Python: ['NumPy', 'Pandas', 'PyTorch', 'scikit-learn', 'FastAPI'],
    TypeScript: ['JavaScript', 'React', 'Vite', 'Node.js', 'WebGPU'],
    JavaScript: ['TypeScript', 'React', 'Node.js', 'Canvas'],
    SQL: ['MongoDB', 'Pandas', 'REST APIs'],
    HTML: ['CSS', 'React', 'Canvas'],
    CSS: ['HTML', 'Tailwind CSS', 'React'],
    WGSL: ['WebGPU', 'Canvas', 'C'],
    PyTorch: ['NumPy', 'scikit-learn', 'Deep Learning', 'TransformerLens', 'Python'],
    'scikit-learn': ['NumPy', 'Pandas', 'Python', 'PyTorch'],
    NumPy: ['Pandas', 'PyTorch', 'scikit-learn', 'Python'],
    Pandas: ['NumPy', 'SQL', 'scikit-learn', 'Python'],
    TransformerLens: ['PyTorch', 'Deep Learning', 'LLM Evaluation', 'RAG'],
    'LLM Evaluation': ['RAG', 'Failure Taxonomy', 'TransformerLens', 'OpenRouter API'],
    RAG: ['LLM Evaluation', 'Failure Taxonomy', 'FastAPI', 'OpenRouter API'],
    'Failure Taxonomy': ['LLM Evaluation', 'RAG'],
    'Deep Learning': ['PyTorch', 'TransformerLens', 'WebGPU'],
    React: ['TypeScript', 'JavaScript', 'Tailwind CSS', 'Vite', 'Canvas'],
    'Tailwind CSS': ['CSS', 'React', 'HTML'],
    Vite: ['React', 'TypeScript', 'WebGPU', 'Astro'],
    Astro: ['Vite', 'React', 'TypeScript', 'Tailwind CSS', 'HTML'],
    WebGPU: ['WGSL', 'Deep Learning', 'Canvas', 'TypeScript'],
    PWA: ['IndexedDB / Dexie.js', 'Web Workers', 'React'],
    'IndexedDB / Dexie.js': ['PWA', 'Web Workers', 'SQL', 'MongoDB'],
    Canvas: ['WebGPU', 'WGSL', 'JavaScript', 'HTML'],
    'Web Workers': ['PWA', 'IndexedDB / Dexie.js', 'WebGPU'],
    FastAPI: ['Pydantic', 'Python', 'REST APIs', 'RAG'],
    Pydantic: ['FastAPI', 'Python'],
    'Node.js': ['Express', 'TypeScript', 'JavaScript', 'REST APIs'],
    Express: ['Node.js', 'REST APIs', 'MongoDB'],
    MongoDB: ['Express', 'SQL', 'IndexedDB / Dexie.js'],
    'REST APIs': ['FastAPI', 'Express', 'Node.js', 'OpenRouter API'],
    Git: ['Linux', 'C'],
    Linux: ['Git', 'C', 'Python'],
    'OpenRouter API': ['RAG', 'LLM Evaluation', 'REST APIs'],
  };

  const STATS: Record<string, [string, number][]> = {
    C: [['uptime', 92], ['footgun risk', 94], ['segfaults/hr', 61]],
    Python: [['versatility', 98], ['import time', 44], ['footgun risk', 30]],
    TypeScript: [['type safety', 97], ['compile spite', 38], ['red squigglies', 70]],
    JavaScript: [['reach', 95], ['this binding', 18], ['footgun risk', 80]],
    SQL: [['join power', 78], ['null surprises', 55], ['uptime', 84]],
    HTML: [['semantics', 80], ['div soup risk', 46], ['uptime', 99]],
    CSS: [['specificity', 72], ['centering pain', 60], ['!important debt', 35]],
    WGSL: [['draw calls', 66], ['GPU heat', 58], ['docs scarcity', 78]],
    PyTorch: [['grad flow', 90], ['VRAM hunger', 74], ['uptime', 82]],
    'scikit-learn': [['fit speed', 84], ['baseline power', 90], ['footgun risk', 24]],
    NumPy: [['vector throughput', 94], ['broadcast magic', 88], ['off-by-one risk', 40]],
    Pandas: [['wrangle power', 88], ['memory bloat', 66], ['SettingWithCopy', 58]],
    TransformerLens: [['interpretability', 90], ['hook depth', 84], ['docs scarcity', 55]],
    'LLM Evaluation': [['signal/noise', 82], ['rubric rigor', 86], ['flake risk', 48]],
    RAG: [['recall', 80], ['hallucination dmg', -1], ['latency', 54]],
    'Failure Taxonomy': [['coverage', 76], ['bug clarity', 84], ['tedium', 70]],
    'Deep Learning': [['raw power', 92], ['compute cost', 80], ['interpretability', 36]],
    React: [['render speed', 90], ['re-render risk', 58], ['ecosystem', 98]],
    'Tailwind CSS': [['ship speed', 90], ['class length', 84], ['readability', 52]],
    Vite: [['HMR speed', 96], ['cold start', 22], ['uptime', 88]],
    Astro: [['ship speed', 92], ['islands', 84], ['zero-JS default', 80]],
    WebGPU: [['draw calls', 88], ['browser support', 58], ['GPU heat', 62]],
    PWA: [['offline armor', 86], ['install lure', 70], ['cache traps', 55]],
    'IndexedDB / Dexie.js': [['storage', 80], ['query ergonomics', 74], ['API jank', 60]],
    Canvas: [['pixel control', 82], ['state churn', 64], ['a11y', 30]],
    'Web Workers': [['thread relief', 84], ['msg overhead', 46], ['debug pain', 58]],
    FastAPI: [['throughput', 88], ['typing', 90], ['footgun risk', 26]],
    Pydantic: [['validation', 90], ['coercion surprises', 48], ['uptime', 84]],
    'Node.js': [['I/O power', 86], ['callback risk', 44], ['ecosystem', 96]],
    Express: [['routing', 78], ['middleware sprawl', 56], ['uptime', 80]],
    MongoDB: [['flex schema', 78], ['consistency', 52], ['scale', 74]],
    'REST APIs': [['clarity', 84], ['over-fetch risk', 50], ['uptime', 88]],
    Git: [['recoverability', 92], ['rebase fear', 62], ['uptime', 98]],
    Linux: [['control', 94], ['learning cliff', 70], ['uptime', 99]],
    'OpenRouter API': [['model reach', 88], ['rate limits', 48], ['latency', 56]],
  };

  const QUIPS: Record<string, string> = {
    C: 'C? bold. respect the segfaults.',
    Python: 'python. the swiss army duct tape.',
    TypeScript: 'types on. squigglies appeased.',
    JavaScript: 'js again? brave or tired.',
    SQL: 'join responsibly.',
    HTML: 'the skeleton. underrated.',
    CSS: 'centered it? prove it.',
    WGSL: 'shaders. flexing the GPU, are we.',
    PyTorch: 'gradients flowing. fans spinning.',
    'scikit-learn': 'baseline first. classy.',
    NumPy: 'vectorized. tasteful.',
    Pandas: 'mind the SettingWithCopy.',
    TransformerLens: 'peeking inside the model. nosy.',
    'LLM Evaluation': 'actually measuring it? rare.',
    RAG: 'retrieve, then pretend you knew.',
    'Failure Taxonomy': 'cataloguing bugs. ominous.',
    'Deep Learning': 'big compute energy.',
    React: 'react again... fine. it ships.',
    Astro: 'astro. ships html, hides the js. sneaky.',
    'Tailwind CSS': 'class names longer than the file.',
    Vite: 'HMR so fast it’s showing off.',
    WebGPU: 'draw calls go brrr.',
    PWA: 'offline armor equipped.',
    'IndexedDB / Dexie.js': 'storing it client-side. trusting.',
    Canvas: 'pixels by hand. masochist.',
    'Web Workers': 'threading the needle.',
    FastAPI: 'typed endpoints. chef’s kiss.',
    Pydantic: 'validates everything but my feelings.',
    'Node.js': 'callbacks, but make it async.',
    Express: 'middleware sprawl incoming.',
    MongoDB: 'schema? we don’t do that here.',
    'REST APIs': 'GET it together. you did.',
    Git: 'rebase fear is real. you’ll live.',
    Linux: 'control freak. approved.',
    'OpenRouter API': 'one key, many models. greedy.',
  };

  const IDLE = [
    '> companion online. show me the build.',
    "> hover a slot. i'll judge it.",
    '> a loadout is only as good as its set bonuses.',
    "> i've seen worse stacks. recently. not many.",
  ];

  function initLoadout() {
    const loadout = document.getElementById('loadout');
    const card = document.getElementById('ld-card');
    const logText = document.getElementById('logText');
    const bubble = document.getElementById('catSay');
    if (!loadout || !card || !logText) return;

    const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const GLYPHS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789#%&@/<>*+=-';

    // symmetric adjacency for set bonuses
    const ADJ: Record<string, string[]> = {};
    const ensure = (k: string) => { if (!ADJ[k]) ADJ[k] = []; };
    const addEdge = (a: string, b: string) => { ensure(a); if (ADJ[a].indexOf(b) < 0) ADJ[a].push(b); };
    Object.keys(RELATED).forEach((k) => ensure(k));
    Object.keys(RELATED).forEach((k) => RELATED[k].forEach((v) => { addEdge(k, v); addEdge(v, k); }));

    const rarityOf = (w: number) => (w >= 5 ? 'LEGENDARY' : w >= 4 ? 'EPIC' : 'RARE');
    const esc = (s: string) => s.replace(/[&<>"']/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m] as string));

    // collect server-rendered slots
    const slotEls: Record<string, HTMLElement> = {};
    loadout.querySelectorAll<HTMLElement>('.slot[data-name]').forEach((el) => {
      const n = el.dataset.name;
      if (n) slotEls[n] = el;
    });

    let activeName: string | null = null;
    let pinnedName: string | null = null;

    /* ---- fit names: shrink to <=2 lines, never mid-word ---- */
    function fitNames() {
      loadout!.querySelectorAll<HTMLElement>('.slot .name').forEach((el) => {
        let size = 12; const min = 7; let guard = 0;
        el.style.fontSize = size + 'px';
        while (size > min && guard < 24) {
          const overW = el.scrollWidth > el.clientWidth + 1;
          const overH = el.scrollHeight > Math.ceil(size * 1.12 * 2) + 1;
          if (!overW && !overH) break;
          size -= 0.5; guard++;
          el.style.fontSize = size + 'px';
        }
      });
    }

    /* ---- decode-in labels (deterministic per index) ---- */
    function decode(el: HTMLElement, idx: number) {
      const target = el.dataset.text || '';
      if (REDUCED) { el.textContent = target; return; }
      const steps = 7; let frame = 0;
      let seed = (idx * 2654435761) >>> 0;
      const rnd = () => { seed = (seed * 1664525 + 1013904223) >>> 0; return seed / 4294967296; };
      const settle = target.split('').map(() => Math.floor(rnd() * steps * 0.6) + 1);
      const timer = setInterval(() => {
        let out = '';
        for (let i = 0; i < target.length; i++) {
          const ch = target[i];
          if (ch === ' ') { out += ' '; continue; }
          out += frame >= settle[i] ? ch : GLYPHS[Math.floor(rnd() * GLYPHS.length)];
        }
        el.textContent = out;
        frame++;
        if (frame > steps) { el.textContent = target; clearInterval(timer); }
      }, 34);
    }
    function runDecodeWave() {
      const labels = Array.from(loadout!.querySelectorAll<HTMLElement>('.slot .decode'));
      labels.forEach((el, i) => { el.textContent = ''; window.setTimeout(() => decode(el, i), REDUCED ? 0 : i * 18); });
    }

    /* ---- inspect / set bonus ---- */
    function partnersOf(name: string) { return (ADJ[name] || []).filter((r) => slotEls[r]); }

    function inspect(name: string) {
      activeName = name;
      const slot = slotEls[name];
      const weight = parseInt(slot.dataset.weight || '4', 10);
      const group = slot.dataset.group || '';
      const rar = rarityOf(weight);
      const partners = partnersOf(name);

      loadout!.classList.add('inspecting');
      Object.keys(slotEls).forEach((k) => slotEls[k].classList.remove('is-active', 'is-set'));
      slot.classList.add('is-active');
      partners.forEach((p) => slotEls[p].classList.add('is-set'));

      buildCard(name, group, weight, rar, partners);
      updateLog(name, rar, partners.length);
      catReact(name, rar, partners.length);
    }

    function clearInspect() {
      activeName = null;
      loadout!.classList.remove('inspecting');
      Object.keys(slotEls).forEach((k) => slotEls[k].classList.remove('is-active', 'is-set', 'is-pinned'));
      hideCard();
      logText!.innerHTML = 'idle — hover or tap a slot to inspect equipped gear';
      if (bubble) { bubble.classList.remove('pop'); bubble.textContent = catIdle(); }
    }

    function togglePin(name: string, slot: HTMLElement) {
      if (pinnedName === name) { unpin(); return; }
      pinnedName = name;
      inspect(name);
      Object.keys(slotEls).forEach((k) => slotEls[k].classList.remove('is-pinned'));
      slot.classList.add('is-pinned');
      positionCardForEl(slot);
      card!.classList.add('pinned');
    }
    function unpin() { pinnedName = null; card!.classList.remove('pinned'); clearInspect(); }
    function restoreOrClear() {
      if (pinnedName) {
        const slot = slotEls[pinnedName];
        inspect(pinnedName);
        slot.classList.add('is-pinned');
        positionCardForEl(slot);
        return;
      }
      clearInspect();
    }

    /* ---- item card ---- */
    function buildCard(name: string, group: string, weight: number, rar: string, partners: string[]) {
      const leg = rar === 'LEGENDARY';
      // the card wears the same tier as the slot it describes
      card!.className = 'ld-card ' + (leg ? 'leg' : weight >= 4 ? 'epic' : 'rare');
      const stats = STATS[name] || [['uptime', weight * 20], ['footgun risk', (6 - weight) * 17], ['throughput', weight * 20 - 8]];
      const statsHtml = stats.map((s) => {
        const val = s[1];
        let display: string, pct: number;
        if (val < 0) { display = '0'; pct = 6; } else { display = String(val); pct = Math.max(4, Math.min(100, val)); }
        return '<div class="stat"><span class="k">' + esc(s[0]) + '</span><span class="bar"><i style="width:' + pct + '%"></i></span><span class="v">' + display + '</span></div>';
      }).join('');
      const setHtml = partners.map((p) => '<li>' + esc(p) + '</li>').join('');
      card!.innerHTML =
        '<div class="card-hd"><div class="nm">' + esc(name) + '</div><div class="rtag">' + rar + '</div></div>' +
        '<div class="card-cls">CLASS: <b>' + esc(group) + '</b> &middot; LVL ' + weight + '/5</div>' +
        '<div class="card-stats">' + statsHtml + '</div>' +
        '<div class="card-set"><div class="set-lab">SET BONUS / PAIRS WITH <span class="bonus">+' + partners.length + '</span></div>' +
        '<ul>' + (setHtml || '<li>solo build</li>') + '</ul></div>';
      card!.classList.add('show');
      card!.setAttribute('aria-hidden', 'false');
    }
    function hideCard() { card!.classList.remove('show'); card!.setAttribute('aria-hidden', 'true'); }

    /* Flip, don't clamp. Clamping slid the card to the far edge of the screen and
       left it stranded away from the cursor; flipping keeps it tucked against the
       pointer on whichever side has room. HEAD_SAFE clears the fixed browser
       notice + nav rail, which the card used to slide underneath. */
    const HEAD_SAFE = 88;
    function placeCard(px: number, py: number) {
      const cw = card!.offsetWidth || 248, ch = card!.offsetHeight || 240;
      const pad = 12, gap = 14, vw = window.innerWidth, vh = window.innerHeight;

      let x = px + gap;
      if (x + cw + pad > vw) x = px - cw - gap;          // flip to the left of the pointer
      x = Math.max(pad, Math.min(x, vw - cw - pad));

      let y = py + gap;
      if (y + ch + pad > vh) y = py - ch - gap;          // flip above the pointer
      y = Math.max(HEAD_SAFE, Math.min(y, vh - ch - pad));

      card!.style.left = x + 'px'; card!.style.top = y + 'px';
    }
    function positionCard(e: MouseEvent) { if (card!.classList.contains('show')) placeCard(e.clientX, e.clientY); }
    // keyboard focus and scroll have no pointer — anchor to the slot's right edge instead
    function positionCardForEl(el: HTMLElement) { const r = el.getBoundingClientRect(); placeCard(r.right, r.top + r.height / 2); }

    /* ---- readout ---- */
    function updateLog(name: string, rar: string, count: number) {
      const rarSpan = rar === 'LEGENDARY' ? '<span class="leg">[' + rar + ']</span>' : '<span class="hl">[' + rar + ']</span>';
      logText!.innerHTML =
        'equipped: <span class="hl">' + esc(name.toUpperCase()) + '</span> ' + rarSpan +
        ' <span class="dim">&middot;</span> set: <span class="hl">+' + count + '</span> ' +
        '<span class="dim">' + (count === 1 ? 'partner' : 'partners') + ' lit</span>';
    }

    /* ---- companion cat ---- */
    let idleIdx = 0;
    function catIdle() { idleIdx = (idleIdx + 1) % IDLE.length; return IDLE[idleIdx]; }
    function catReact(name: string, rar: string, count: number) {
      if (!bubble) return;
      let line = QUIPS[name];
      if (!line) line = rar === 'LEGENDARY' ? "legendary. now don't fumble it." : rar === 'EPIC' ? 'epic tier. respectable.' : "rare-grade. it'll do.";
      const prefix = rar === 'LEGENDARY' ? '> ★ ' : '> ';
      if (count >= 5) line += ' huge set, btw.';
      bubble.textContent = prefix + line;
      if (!REDUCED) { bubble.classList.remove('pop'); void bubble.offsetWidth; bubble.classList.add('pop'); }
    }

    /* ---- wire up slots ---- */
    Object.keys(slotEls).forEach((name) => {
      const slot = slotEls[name];
      slot.addEventListener('mouseenter', (e) => { inspect(name); positionCard(e as MouseEvent); });
      slot.addEventListener('mousemove', (e) => { if (!pinnedName || pinnedName === name) positionCard(e as MouseEvent); });
      slot.addEventListener('focus', () => { inspect(name); positionCardForEl(slot); });
      slot.addEventListener('mouseleave', restoreOrClear);
      slot.addEventListener('blur', restoreOrClear);
      slot.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); togglePin(name, slot); });
    });

    document.addEventListener('click', (e) => {
      if (!pinnedName) return;
      const t = e.target as HTMLElement;
      if (t.closest && t.closest('#stack .slot')) return;
      unpin();
    });
    document.addEventListener('keydown', (e) => { if ((e.key === 'Escape' || e.key === 'Esc') && pinnedName) unpin(); });
    window.addEventListener('scroll', () => { if (activeName) positionCardForEl(slotEls[activeName]); }, { passive: true });

    let fitRAF = 0;
    window.addEventListener('resize', () => {
      if (activeName) positionCardForEl(slotEls[activeName]);
      if (fitRAF) cancelAnimationFrame(fitRAF);
      fitRAF = requestAnimationFrame(fitNames);
    });

    // companion cat: fixed bottom-right, visible only while a meaningful chunk of
    // the stack section is on screen (scroll-driven so it works with Lenis smooth-scroll)
    const catEl = document.getElementById('cat');
    const secEl = document.getElementById('stack');
    let catRAF = 0;
    function updateCat() {
      if (!catEl || !secEl) return;
      const r = secEl.getBoundingClientRect();
      const vh = window.innerHeight || document.documentElement.clientHeight;
      const visible = r.top < vh * 0.85 && r.bottom > vh * 0.2;
      catEl.classList.toggle('in-view', visible);
    }
    // creative heading: clip-rise lines + a lime strike that draws through "bookmarked"
    const headEl = document.getElementById('ld-head');
    if (headEl && !REDUCED) headEl.classList.add('armed'); // armed only with JS+motion; no-JS stays visible
    let headRevealed = false;
    function revealHead() {
      if (headRevealed || !headEl) return;
      const r = headEl.getBoundingClientRect();
      const vh = window.innerHeight || document.documentElement.clientHeight;
      if (r.top < vh * 0.9 && r.bottom > 0) { headEl.classList.add('revealed'); headRevealed = true; }
    }

    window.addEventListener('scroll', () => {
      if (catRAF) cancelAnimationFrame(catRAF);
      catRAF = requestAnimationFrame(() => { updateCat(); revealHead(); });
    }, { passive: true });
    window.addEventListener('resize', () => { updateCat(); });
    updateCat();
    revealHead();

    function boot() {
      if (bubble) bubble.textContent = IDLE[0];
      fitNames();
      runDecodeWave();
    }
    if (document.fonts && (document.fonts as any).ready) {
      (document.fonts as any).ready.then(boot);
      window.setTimeout(() => {
        const first = loadout!.querySelector('.slot .decode');
        if (first && first.textContent === '') boot();
      }, 800);
    } else {
      boot();
    }
  }

  /* ---- UV lamp: on the night desk the cursor is a blacklight — it reveals
     lime marginalia (graffiti, commit notes, paw prints) hidden on the ink
     field. Posterized pool: hard alpha bands, no gradients. Touch gets one
     slow sweep on entry; reduced motion gets a faint static print. ---- */
  function initNightLamp() {
    const section = document.getElementById('stack');
    if (!section || (section as any)._uvInit) return;
    (section as any)._uvInit = true;

    const PRM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const cv = document.createElement('canvas');
    cv.className = 'uv-cv';
    cv.setAttribute('aria-hidden', 'true');
    section.prepend(cv);
    const ctx = cv.getContext('2d');
    if (!ctx) return;
    const dpr = Math.min(1.5, window.devicePixelRatio || 1);

    const NOTES = [
      'stderr was here',
      'a3f9c12 — 03:11, finally green',
      '> tests passed. suspicious.',
      'TODO: sleep (wontfix)',
      '4 a.m. is a timezone',
      'git blame says it was me',
      'shift 23:00 – 07:00',
      '> compiled first try. checked twice.',
      'coffee #4, regrets #0',
      'the bug was a feature flag',
    ];

    type Note = { x: number; y: number; rot: number; text?: string; paw?: boolean; size: number };
    let notes: Note[] = [];
    let W = 0, H = 0;

    function build() {
      W = Math.max(1, section!.offsetWidth);
      H = Math.max(1, section!.offsetHeight);
      cv.width = Math.round(W * dpr);
      cv.height = Math.round(H * dpr);
      cv.style.width = W + 'px';
      cv.style.height = H + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      let seed = 127;
      const rnd = () => ((seed = (seed * 1664525 + 1013904223) >>> 0), seed / 4294967296);
      notes = [];
      const n = Math.round((W * H) / 52000);
      // even (stratified) scatter: one note per grid cell + jitter, so the
      // marginalia covers the desk uniformly instead of clumping the way pure
      // random placement does (some corners packed, others bare)
      const cols = Math.max(1, Math.round(Math.sqrt(n * (W / Math.max(1, H)))));
      const rows = Math.max(1, Math.ceil(n / cols));
      const cellW = W / cols;
      const cellH = (H - 100) / rows;
      let i = 0;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols && i < n; c++, i++) {
          const paw = i % 6 === 5;
          notes.push({
            x: (c + 0.5) * cellW + (rnd() - 0.5) * cellW * 0.7,
            y: 50 + (r + 0.5) * cellH + (rnd() - 0.5) * cellH * 0.7,
            rot: (rnd() - 0.5) * 0.16,
            text: paw ? undefined : NOTES[i % NOTES.length],
            paw,
            size: 10 + rnd() * 3,
          });
        }
      }
    }

    function drawNote(nt: Note, alpha: number) {
      ctx!.save();
      ctx!.translate(nt.x, nt.y);
      ctx!.rotate(nt.rot);
      ctx!.fillStyle = 'rgba(180,255,46,' + alpha.toFixed(3) + ')';
      if (nt.paw) {
        ctx!.beginPath();
        ctx!.ellipse(0, 0, nt.size * 0.5, nt.size * 0.42, 0, 0, Math.PI * 2);
        for (let i = -1; i <= 1; i++) {
          ctx!.ellipse(i * nt.size * 0.45, -nt.size * 0.64, nt.size * 0.17, nt.size * 0.22, 0, 0, Math.PI * 2);
        }
        ctx!.fill();
      } else {
        ctx!.font = '700 ' + nt.size + 'px "JetBrains Mono", monospace';
        ctx!.fillText(nt.text!, 0, 0);
      }
      ctx!.restore();
    }

    /* posterized lamp: hard alpha bands by distance — no gradient falloff */
    const BANDS: Array<[number, number]> = [[72, 0.9], [114, 0.4], [152, 0.14]];
    const bandAlpha = (d: number) => {
      for (const [r, a] of BANDS) if (d < r) return a;
      return 0;
    };

    let lx = 0, ly = 0, tx = -9999, ty = -9999, on = false, glow = 0, raf = 0;
    function frame() {
      lx += (tx - lx) * 0.2;
      ly += (ty - ly) * 0.2;
      glow += ((on ? 1 : 0) - glow) * 0.14;
      ctx!.clearRect(0, 0, W, H);
      if (glow < 0.02 && !on) { raf = 0; return; }
      for (const nt of notes) {
        const a = bandAlpha(Math.hypot(nt.x - lx, nt.y - ly)) * glow;
        if (a > 0) drawNote(nt, a);
      }
      ctx!.lineWidth = 1.5;
      ctx!.strokeStyle = 'rgba(180,255,46,' + (0.1 * glow).toFixed(3) + ')';
      ctx!.beginPath(); ctx!.arc(lx, ly, BANDS[0][0], 0, Math.PI * 2); ctx!.stroke();
      ctx!.strokeStyle = 'rgba(180,255,46,' + (0.05 * glow).toFixed(3) + ')';
      ctx!.beginPath(); ctx!.arc(lx, ly, BANDS[1][0], 0, Math.PI * 2); ctx!.stroke();
      raf = requestAnimationFrame(frame);
    }
    /* layout can shift after init (fonts, late images, odd first-paint
       viewports) — re-measure whenever the lamp actually turns on */
    const ensureSize = () => {
      if (Math.abs(section!.offsetWidth - W) > 1 || Math.abs(section!.offsetHeight - H) > 1) build();
    };
    const start = () => {
      ensureSize();
      if (!raf) raf = requestAnimationFrame(frame);
    };

    build();
    let rt = 0;
    window.addEventListener('resize', () => { window.clearTimeout(rt); rt = window.setTimeout(build, 200); });

    if (PRM) {
      /* reduced motion: faint static print, no lamp, no loop */
      for (const nt of notes) drawNote(nt, 0.13);
      return;
    }

    if (window.matchMedia('(hover: none)').matches) {
      /* touch: one slow sweep across the desk when it first scrolls in */
      if (typeof IntersectionObserver === 'undefined') return;
      const io = new IntersectionObserver((es) => {
        es.forEach((en) => {
          if (!en.isIntersecting) return;
          io.disconnect();
          ensureSize(); /* sweep geometry depends on fresh W/H */
          const t0 = performance.now();
          ly = ty = Math.min(H * 0.4, 420);
          lx = tx = -160;
          on = true;
          const sweep = (now: number) => {
            const k = Math.min(1, (now - t0) / 2800);
            tx = -160 + (W + 320) * k;
            if (k < 1) requestAnimationFrame(sweep);
            else on = false;
          };
          requestAnimationFrame(sweep);
          start();
        });
      }, { rootMargin: '0px 0px -25% 0px' });
      io.observe(section);
      return;
    }

    /* desktop: the pointer is the lamp */
    const localXY = (e: PointerEvent): [number, number] => {
      const r = section!.getBoundingClientRect();
      return [e.clientX - r.left, e.clientY - r.top];
    };
    section.addEventListener('pointerenter', (e) => {
      const [x, y] = localXY(e);
      lx = tx = x; ly = ty = y;
      on = true;
      start();
    });
    section.addEventListener('pointermove', (e) => {
      const [x, y] = localXY(e);
      tx = x; ty = y;
      on = true;
      start();
    }, { passive: true });
    section.addEventListener('pointerleave', () => { on = false; start(); });
  }

  function initStack() {
    initLoadout();
    initNightLamp();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initStack);
  else initStack();
</script>
