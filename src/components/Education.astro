    }
  }

  /* ---------- REDUCED MOTION ---------- */
  @media (prefers-reduced-motion: reduce) {
    .edu-card.shake {
      animation: none;
    }
    .mast-stamp .mast-dot {
      animation: none;
      opacity: 1;
    }
    .mast-title .mt-in {
      transition: none;
    }
    .mast-title .mt-stamp {
      animation: none !important;
    }
    .marker .blk.beat {
      animation: none;
    }
    .rail-fill {
      transition: none;
    }
    .sgpa-col .fill {
      transition: none;
    }
    .stamp.armed {
      opacity: 1;
      transform: rotate(var(--rot));
    }
    .stamp.punch {
      animation: none;
      opacity: 1;
      transform: rotate(var(--rot));
    }
    .chip .wipe {
      transition: none;
    }
    .edu-card,
    .stamp,
    .edu-btn {
      transition: none;
    }
  }
</style>

<script>
  function initEducation() {
    const root = document.getElementById('education');
    if (!root) return;
    const REDUCE = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const clamp = (v: number, lo: number, hi: number) => Math.max(lo, Math.min(hi, v));

    const track = root.querySelector('.track') as HTMLElement;
    const START = Number(track.dataset.start);
    const END = Number(track.dataset.end);
    const railFill = root.querySelector('.rail-fill') as HTMLElement;
    const marker = root.querySelector('.marker') as HTMLElement;
    const mblk = root.querySelector('.marker .blk') as HTMLElement;
    const pop = root.querySelector('.pop') as HTMLElement;
    const tickEls = Array.from(root.querySelectorAll('.tick')) as HTMLElement[];
    const blockReadout = root.querySelector('.ro-blocks') as HTMLElement;
    const pctCounter = root.querySelector('.ro-num') as HTMLElement;
    const card = root.querySelector('.edu-card') as HTMLElement;
    const sgChart = root.querySelector('.sgpa-chart') as HTMLElement;
    const liveTxt = root.querySelector('.mast-live-txt') as HTMLElement | null;
    const mastTitle = root.querySelector('.mast-title') as HTMLElement | null;

    /* ---------- live date math ---------- */
    function computeState() {
      const now = Date.now();
      const p = clamp(((now - START) / (END - START)) * 100, 0, 100);
      let completed = 0;
      tickEls.forEach((t) => {
        if (Number(t.dataset.end) < now) completed++;
      });
      let current = 0;
      for (const t of tickEls) {
        const s = Number(t.dataset.start);
        const e = Number(t.dataset.end);
        if (now >= s && now <= e) {
          current = Number(t.dataset.id);
          break;
        }
      }
      if (current === 0) current = completed > 0 ? completed : 1;
      const block = '■'.repeat(completed) + '□'.repeat(8 - completed) + '  ' + Math.round(p) + '% · SEMESTER ' + current;
      return { now, pct: p, completed, current, block };
    }
    let state = computeState();

    function applyLive() {
      state = computeState();
      tickEls.forEach((t) => {
        const done = Number(t.dataset.end) < state.now;
        t.classList.toggle('done', done);
        t.classList.toggle('upcoming', !done);
        t.classList.toggle('current', Number(t.dataset.id) === state.current);
      });
      marker.style.left = state.pct + '%';
      railFill.style.width = state.pct + '%';
      blockReadout.textContent = state.block;
      pctCounter.textContent = String(Math.round(state.pct));
      if (liveTxt) liveTxt.textContent = 'SEM ' + state.current + ' · ' + Math.round(state.pct) + '%';
    }
    if (REDUCE) railFill.style.transition = 'none';
    applyLive();

    /* ---------- popover ---------- */
    const pTerm = pop.querySelector('.pterm') as HTMLElement;
    const pRng = pop.querySelector('.prng') as HTMLElement;
    const pSg = pop.querySelector('.prow b') as HTMLElement;
    const pAch = pop.querySelector('.pach') as HTMLElement;
    const pAchTxt = pop.querySelector('.pach-txt') as HTMLElement;
    const pStatus = pop.querySelector('.pstatus') as HTMLElement;
    const pToday = pop.querySelector('.ptoday') as HTMLElement;

    function openPop(t: HTMLElement, isToday: boolean) {
      const sgRaw = t.dataset.sgpa || '';
      const ach = t.dataset.ach || '';
      const end = Number(t.dataset.end);
      const id = Number(t.dataset.id);
      pTerm.textContent = t.dataset.name || '';
      pRng.textContent = t.dataset.range || '';
      pSg.textContent = sgRaw ? Number(sgRaw).toFixed(2) : '—';
      if (ach) {
        pAch.style.display = '';
        pAchTxt.textContent = ach;
      } else {
        pAch.style.display = 'none';
      }
      pStatus.textContent = end < state.now ? 'COMPLETED' : id === state.current ? 'IN PROGRESS' : 'UPCOMING · NOT YET GRADED';
      pToday.style.display = isToday ? '' : 'none';

      const wrap = track.parentElement as HTMLElement;
      const a = t.getBoundingClientRect();
      const w = wrap.getBoundingClientRect();
      let cx = a.left + a.width / 2 - w.left;
      pop.style.display = 'block';
      pop.classList.add('on');
      const pw = pop.offsetWidth;
      cx = clamp(cx, pw / 2 + 4, w.width - pw / 2 - 4);
      pop.style.left = cx + 'px';
      pop.style.top = '-2px';
      pop.style.transform = 'translate(-50%, -100%)';
    }
    function closePop() {
      pop.classList.remove('on');
      pop.style.display = 'none';
    }
    closePop();

    tickEls.forEach((t) => {
      const hot = t.querySelector('.hot') as HTMLElement;
      const show = () => {
        openPop(t, false);
        t.classList.add('show');
      };
      const hide = () => {
        closePop();
        t.classList.remove('show');
      };
      hot.addEventListener('mouseenter', show);
      hot.addEventListener('mouseleave', hide);
      hot.addEventListener('focus', show);
      hot.addEventListener('blur', hide);
    });

    const curTick = () => tickEls.find((t) => Number(t.dataset.id) === state.current) || tickEls[0];
    mblk.setAttribute('tabindex', '0');
    mblk.setAttribute('role', 'button');
    mblk.addEventListener('mouseenter', () => openPop(curTick(), true));
    mblk.addEventListener('mouseleave', closePop);
    mblk.addEventListener('focus', () => openPop(curTick(), true));
    mblk.addEventListener('blur', closePop);

    /* ---------- count-up ---------- */
    function countUp(target: number) {
      if (REDUCE) {
        pctCounter.textContent = String(target);
        return;
      }
      const dur = 700;
      const t0 = performance.now();
      function step(t: number) {
        const k = clamp((t - t0) / dur, 0, 1);
        const e = 1 - Math.pow(1 - k, 3);
        pctCounter.textContent = String(Math.round(target * e));
        if (k < 1) requestAnimationFrame(step);
        else pctCounter.textContent = String(target);
      }
      requestAnimationFrame(step);
    }

    /* ---------- chips: decode-in + press-to-invert ---------- */
    const CHARSET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789/#*<>';
    const rnd = () => CHARSET[(Math.random() * CHARSET.length) | 0];
    const chipEls = Array.from(root.querySelectorAll('.chip')) as HTMLElement[];
    chipEls.forEach((c) => {
      const lab = c.querySelector('label') as HTMLElement;
      const real = (c.dataset.text || lab.textContent || '').toUpperCase();
      (c as any)._real = real;
      (c as any)._lab = lab;
      if (!REDUCE) lab.textContent = '';
      else lab.textContent = real;
      c.addEventListener('click', () => {
        const inv = c.classList.toggle('inv');
        c.setAttribute('aria-pressed', inv ? 'true' : 'false');
      });
    });
    function decodeChip(c: HTMLElement, delay: number) {
      const real: string = (c as any)._real;
      const lab: HTMLElement = (c as any)._lab;
      const len = real.length;
      const dur = 450;
      let t0: number | null = null;
      window.setTimeout(() => {
        function frame(t: number) {
          if (t0 === null) t0 = t;
          const k = clamp((t - t0) / dur, 0, 1);
          const resolved = Math.floor(k * len);
          let out = '';
          for (let i = 0; i < len; i++) {
            const ch = real[i];
            out += i < resolved || ch === ' ' || ch === '&' ? ch : rnd();
          }
          lab.textContent = out;
          if (k < 1) requestAnimationFrame(frame);
          else lab.textContent = real;
        }
        requestAnimationFrame(frame);
      }, delay);
    }

    /* ---------- stamps: punch-in ---------- */
    const stampEls = Array.from(root.querySelectorAll('.stamp')) as HTMLElement[];
    function fireShake() {
      if (REDUCE) return;
      card.classList.remove('shake');
      void card.offsetWidth;
      card.classList.add('shake');
    }
    function punch(el: HTMLElement, delay: number) {
      if (REDUCE) {
        el.classList.remove('armed', 'punch');
        el.classList.add('landed');
        return;
      }
      el.classList.remove('punch', 'landed');
      el.classList.add('armed');
      void el.offsetWidth;
      window.setTimeout(() => {
        el.classList.remove('armed');
        el.classList.add('punch');
        window.setTimeout(() => {
          el.classList.add('thunk');
          fireShake();
          window.setTimeout(() => el.classList.remove('thunk'), 140);
        }, 130);
        window.setTimeout(() => {
          el.classList.remove('punch');
          el.classList.add('landed');
        }, 260);
      }, delay);
    }
    function stampSeq() {
      if (REDUCE) {
        stampEls.forEach((el) => punch(el, 0));
        return;
      }
      stampEls.forEach((el, i) => punch(el, i * 150));
    }
    const restamp = root.querySelector('.edu-restamp') as HTMLElement | null;
    if (restamp) restamp.addEventListener('click', stampSeq);

    /* ---------- reveals: each block animates only when it scrolls into view ---------- */
    const stampRail = root.querySelector('.stamp-rail') as HTMLElement;
    const chipsWrap = root.querySelector('.chips') as HTMLElement;
    const readoutEl = root.querySelector('.readout') as HTMLElement;

    function whenInView(el: HTMLElement, cb: () => void, threshold: number) {
      if (!('IntersectionObserver' in window)) {
        cb();
        return;
      }
      let done = false;
      const fire = () => {
        if (done) return;
        done = true;
        cb();
        io.disconnect();
      };
      const io = new IntersectionObserver((entries) => entries.forEach((en) => en.isIntersecting && fire()), {
        threshold,
      });
      io.observe(el);
      window.setTimeout(() => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight * 0.85 && r.bottom > 0) fire();
      }, 120);
    }

    if (REDUCE) {
      stampEls.forEach((el) => {
        el.classList.remove('armed', 'punch');
        el.classList.add('landed');
      });
      chipEls.forEach((c) => {
        const lab = c.querySelector('label') as HTMLElement;
        lab.textContent = (c as any)._real;
      });
      sgChart.classList.add('is-drawn');
      pctCounter.textContent = String(Math.round(state.pct));
    } else {
      whenInView(
        readoutEl,
        () => {
          sgChart.classList.add('is-drawn');
          pctCounter.textContent = '0';
          requestAnimationFrame(() => countUp(Math.round(state.pct)));
        },
        0.4
      );
      whenInView(stampRail, stampSeq, 0.4);
      whenInView(chipsWrap, () => chipEls.forEach((c, i) => decodeChip(c, i * 45)), 0.3);
      if (mastTitle) {
        mastTitle.classList.add('armed');
        whenInView(mastTitle, () => mastTitle.classList.add('revealed'), 0.2);
      }
    }

    /* ---------- wordmark decode-on-hover ---------- */
    const wm = root.querySelector('.wordmark') as HTMLElement;
    const wmReal = wm.dataset.text || wm.textContent || '';
    let wmRaf = 0;
    function decodeWord() {
      if (REDUCE) {
        wm.textContent = wmReal;
        return;
      }
      cancelAnimationFrame(wmRaf);
      const len = wmReal.length;
      const dur = 420;
      let t0: number | null = null;
      function frame(t: number) {
        if (t0 === null) t0 = t;
        const k = clamp((t - t0) / dur, 0, 1);
        const resolved = Math.floor(k * len);
        let out = '';
        for (let i = 0; i < len; i++) {
          const ch = wmReal[i];
          out += i < resolved || ch === ' ' ? ch : rnd();
        }
        wm.textContent = out;
        if (k < 1) wmRaf = requestAnimationFrame(frame);
        else wm.textContent = wmReal;
      }
      wmRaf = requestAnimationFrame(frame);
    }
    wm.setAttribute('tabindex', '0');
    wm.addEventListener('mouseenter', decodeWord);
    wm.addEventListener('focus', decodeWord);

    /* keep it honest as real time passes */
    window.setInterval(applyLive, 30000);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initEducation);
  else initEducation();
</script>
