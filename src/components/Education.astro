  }

  /* ---------- TRACK ---------- */
  .track-wrap {
    position: relative;
    margin-top: clamp(30px, 4.5vw, 56px);
    padding: 0 6px;
  }
  .track {
    position: relative;
    height: 210px;
  }
  .rail {
    position: absolute;
    left: 0;
    right: 0;
    top: 118px;
