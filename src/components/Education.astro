  .pop {
    position: absolute;
    z-index: 60;
    min-width: 184px;
    max-width: 240px;
    background: var(--black);
    color: var(--cream);
    /* the one dark surface in this light manila section — flip the inherited
       ink/muted/line tokens to their light forms so every descendant reads
       (text was var(--ink) #141414 on #0a0a0a = 1.05:1, invisible) */
    --ink: var(--cream);
