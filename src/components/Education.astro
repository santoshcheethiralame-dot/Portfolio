    background-image: radial-gradient(circle at 18% 30%, rgba(122, 0, 20, 0.12) 0 1px, transparent 1.4px),
      radial-gradient(circle at 62% 70%, rgba(122, 0, 20, 0.1) 0 1px, transparent 1.4px),
      radial-gradient(circle at 84% 22%, rgba(122, 0, 20, 0.1) 0 1px, transparent 1.4px),
