  @keyframes eduPunch {
    0% {
      opacity: 0;
      transform: scale(2.2) rotate(var(--rot-in));
    }
    1% {
      opacity: 1;
    }
    55% {
      transform: scale(0.86) rotate(var(--rot));
      box-shadow: 0 0 0 var(--black);
    }
    72% {
      transform: scale(1.07) rotate(var(--rot));
    }
    86% {
      transform: scale(0.97) rotate(var(--rot));
    }
    100% {
      opacity: 1;
      transform: scale(1) rotate(var(--rot));
    }
  }
  .stamp.thunk {
    box-shadow: 6px 8px 0 var(--black);
  }

  /* ---------- CHIPS ---------- */
  .course-head {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: clamp(20px, 2.6vw, 28px);
    margin-bottom: 12px;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }
  .chip {
    position: relative;
    overflow: hidden;
    border: 1.5px solid var(--ink);
    border-radius: 100px;
    padding: 5px 11px;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink);
    background: transparent;
    cursor: pointer;
    line-height: 1.1;
    transition: transform 110ms cubic-bezier(0.2, 0.9, 0.2, 1);
  }
  .chip:active {
