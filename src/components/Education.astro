  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 760px) {
    .tick .lab .rng {
      display: none;
    }
    .tick .star::after {
      height: 36px;
      top: 24px;
    }
  }
  @media (max-width: 640px) {
    .card-head {
      flex-direction: column;
    }
    .head-right {
      align-items: flex-start;
    }
