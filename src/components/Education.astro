    height: 64px;
    background: transparent;
    border: 0;
    cursor: pointer;
    z-index: 6;
    padding: 0;
  }
  .tick .hot:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: -2px;
  }
  .tick:hover .node,
  .tick.show .node {
    transform: scale(1.42) rotate(45deg);
  }
  .tick .lab {
