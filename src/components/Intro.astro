<script>
  // EDITION ENGINE — press-run via IntersectionObserver on .edition; stderr quips;
  // halftone resolve; editor's-pen draw; lime press-tick; folio clock (own IST interval).
  // Page-turn CTAs jump IN-PAGE to #projects (no navigation).
  (function () {
    'use strict';
    try {
      const edition = document.querySelector<HTMLElement>('.edition');
      if (!edition) return;

      const REDUCE = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const clamp = function (v: number, a: number, b: number) { return v < a ? a : v > b ? b : v; };
      const GLYPHS = 'ABCDEFGHJKLMNPQRSTUVWXYZ#@/*0123456789'.split('');

      /* press-run elements that get a temporary will-change */
      const PR_SEL = '.mast-rule-top,.mast-rule-bot,.dateline-strip,.ticker,.masthead-title,.sticker-late,.deck-kicker,.deck-head,.deck-sub,.byline,.dropcap,.article-flow,.sidebar,.classifieds';

      /* ---------- IST clock in edition folio (unique id) ---------- */
      const clock = edition.querySelector('#ed-clock');
      function tick() {
        try { if (clock) clock.textContent = new Intl.DateTimeFormat('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false, timeZone: 'Asia/Kolkata' }).format(new Date()) + ' IST'; }
        catch (e) { if (clock) clock.textContent = '--:--:-- IST'; }
      }
      tick(); setInterval(tick, 1000);

      /* ---------- the edition reflects the hour + the reader's visit count ---------- */
      (function liveEdition() {
        const edName = edition.querySelector('#ed-edition');
        const edNum = edition.querySelector('#ed-number');
        let hr = 12;
        try {
          hr = parseInt(new Intl.DateTimeFormat('en-GB', { hour: '2-digit', hour12: false, timeZone: 'Asia/Kolkata' }).format(new Date()), 10);
        } catch (e) { /* keep midday default */ }
        let name = 'LATE EDITION';
        if (hr >= 5 && hr < 11) name = 'MORNING EDITION';
        else if (hr >= 11 && hr < 16) name = 'MIDDAY EDITION';
        else if (hr >= 16 && hr < 21) name = 'EVENING EDITION';
        if (edName) edName.textContent = name;
        if (edNum) {
          let n = 1;
          try {
            n = Math.min(999, (parseInt(localStorage.getItem('dc-reads') || '0', 10) || 0) + 1);
            localStorage.setItem('dc-reads', String(n));
          } catch (e) { /* private mode — first edition it is */ }
          edNum.textContent = n === 1 ? 'FIRST EDITION' : 'No. ' + n;
        }
      })();

      /* ---------- the SUBSCRIBE gag (it was never going to charge you) ---------- */
      (function subscribe() {
        const btn = edition.querySelector<HTMLButtonElement>('#cl-sub');
        if (!btn) return;
        const done = () => {
          btn.classList.add('is-subbed');
          btn.disabled = true;
          btn.textContent = "SUBSCRIBED ✓ — SEE YOU AT DAWN";
        };
        let already = false;
        try { already = localStorage.getItem('dc-sub') === '1'; } catch (e) { /* private mode */ }
        if (already) done();
        btn.addEventListener('click', () => {
          try { localStorage.setItem('dc-sub', '1'); } catch (e) { /* ignore */ }
          done();
        });
      })();

      /* ---------- structure-preserving linotype decode ---------- */
      type CharInfo = { nodes: { node: Text; orig: string }[]; total: number };
      function collectChars(ct: any): CharInfo {
        if (ct._chars) return ct._chars;
        const walker = document.createTreeWalker(ct, NodeFilter.SHOW_TEXT, null);
        let n: Node | null;
        const nodes: { node: Text; orig: string }[] = [];
        let total = 0;
        while ((n = walker.nextNode())) { const t = n as Text; nodes.push({ node: t, orig: t.nodeValue || '' }); total += (t.nodeValue || '').length; }
        ct._chars = { nodes: nodes, total: total }; return ct._chars;
      }
      function render(ct: any, rev: number) {
        const info = collectChars(ct);
        let seen = 0;
        info.nodes.forEach(function (it) {
          const o = it.orig;
          let s = '';
          for (let i = 0; i < o.length; i++) {
            const c = o[i];
            s += ((seen + i) < rev || c === ' ' || c === '\n' || c === '—' || c === '·' || c === ',' || c === '.' || c === '’') ? c : GLYPHS[(Math.random() * GLYPHS.length) | 0];
          }
          it.node.nodeValue = s; seen += o.length;
        });
      }
      function decodeEl(ct: any, dur: number) {
        const info = collectChars(ct);
        if (REDUCE) { render(ct, info.total); return; }
        if (ct._raf) cancelAnimationFrame(ct._raf);
        // lock the resolved line box: random ciphertext glyphs run wider than the real
        // letters and would otherwise reflow the headline to an extra line mid-decode
        const el = ct as HTMLElement;
        const lockH = el.offsetHeight;
        if (lockH > 0) { el.style.height = lockH + 'px'; el.style.overflow = 'hidden'; }
        let start: number | null = null;
        function f(now: number) {
          if (start === null) start = now;
          const k = clamp((now - start) / (dur || 600), 0, 1);
          render(ct, Math.floor(k * info.total));
          if (k < 1) ct._raf = requestAnimationFrame(f);
          else { render(ct, info.total); ct._raf = null; el.style.height = ''; el.style.overflow = ''; }
        }
        ct._raf = requestAnimationFrame(f);
      }

      function decodeHeadline() {
        const dh = edition!.querySelector('.deck-head');
        if (dh && !REDUCE) decodeEl(dh, 720);
      }

      /* ---------- PRESS-RUN ---------- */
      /* default: fully visible (no-JS / reduced-motion = finished newspaper) */
      function setWillChange(on: boolean) {
        try {
          edition!.querySelectorAll<HTMLElement>(PR_SEL).forEach(function (el) {
            el.style.willChange = on ? 'transform,opacity' : '';
          });
        } catch (e) { /* noop */ }
      }
      /* The chronicle is VISIBLE BY DEFAULT — no on-load staging, so it can never get stuck hidden
         ("just the cat"). The press-run "print" is a transient enhancement in THREE groups: the
         masthead block prints when the edition scrolls in; the article body and the classifieds
         print when the reader actually reaches them (their own observers) — under a single trigger
         the lower groups finished animating one to two viewports below the fold, unseen.
         A hard safety always ends fully revealed. */
      let prPlayed = false;
      let groupsLeft = 3; /* masthead · body · classifieds */
      let prFinished = false;
      function finish() {
        if (prFinished) return;
        prFinished = true;
        edition!.classList.add('go', 'go-body', 'go-class'); /* nothing may stay staged-hidden */
        edition!.classList.add('pr-done');
        setWillChange(false);
      }
      function groupDone() {
        groupsLeft -= 1;
        if (groupsLeft <= 0) finish();
      }
      /* a lower group prints when its anchor element scrolls into view */
      function armGroup(sel: string, cls: string) {
        const el = edition!.querySelector(sel);
        if (!el || typeof IntersectionObserver === 'undefined') {
          edition!.classList.add(cls);
          groupDone();
          return;
        }
        const gio = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (!e.isIntersecting) return;
            gio.disconnect();
            edition!.classList.add(cls);
            window.setTimeout(groupDone, 1300); /* group's transitions have settled */
          });
        }, { rootMargin: '0px 0px -10% 0px' });
        gio.observe(el);
      }
      let mastGone = false;
      function goMast() {
        if (mastGone) return;
        mastGone = true;
        edition!.classList.add('go'); /* the masthead block prints */
        window.setTimeout(decodeHeadline, 420);
        armGroup('.article-flow', 'go-body');
        armGroup('.classifieds', 'go-class');
      }
      function play() {
        if (prPlayed) return;
        prPlayed = true;
        if (REDUCE) return; /* reduced motion: leave the finished chronicle as-is */
        setWillChange(true);
        edition!.classList.add('pressrun'); /* stage hidden… */
        requestAnimationFrame(function () {
          requestAnimationFrame(goMast);
        });
        window.setTimeout(goMast, 350); /* rAF can stall in background tabs — never stay staged */
        window.setTimeout(groupDone, 1500); /* masthead block has finished */
        /* HARD SAFETY: whatever happens, end fully revealed with will-change cleared */
        window.setTimeout(finish, 12000);
      }

      if (!REDUCE && typeof IntersectionObserver !== 'undefined') {
        /* fire the print as the edition begins to cover the hero — IO is reliable under Lenis + sticky
           (no scroll-event dependency). If it never fires, the chronicle simply stays visible. */
        const io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { if (e.isIntersecting) { io.disconnect(); play(); } });
        }, { rootMargin: '0px 0px -8% 0px' });
        io.observe(edition);
      }

      /* ---------- lime press-tick (reading-position cue) ---------- */
      const pressTick = edition.querySelector<HTMLElement>('#pressTick');
      const articleFlow = edition.querySelector<HTMLElement>('.article-flow');
      function placeTick() {
        if (!pressTick || !articleFlow) return;
        if (getComputedStyle(pressTick).display === 'none') return;
        const ar = articleFlow.getBoundingClientRect();
        const viewH = window.innerHeight;
        const articleTop = ar.top; const articleBot = ar.bottom;
        const p = clamp((viewH - articleTop) / (articleBot - articleTop + viewH), 0, 1);
        const travel = articleFlow.clientHeight - pressTick.offsetHeight;
        pressTick.style.top = (p * travel).toFixed(1) + 'px';
      }

      /* ---------- STDERR live-edits ---------- */
      const logBox = edition.querySelector('#stderrLog');
      function pushLog(text: string) {
        if (!logBox) return;
        const el = document.createElement('span'); el.className = 'log-line'; logBox.appendChild(el);
        while (logBox.children.length > 4) { logBox.removeChild(logBox.firstChild!); }
        (el as any)._chars = null; el.textContent = text; decodeEl(el, 420);
      }

      if (typeof IntersectionObserver !== 'undefined') {
        const quipObs = new IntersectionObserver(function (es) {
          es.forEach(function (e) {
            const tgt = e.target as any;
            if (e.isIntersecting && !tgt._fired) {
              tgt._fired = true;
              const q = e.target.getAttribute('data-quip'); if (q) pushLog(q);
            }
          });
        }, { rootMargin: '0px 0px -45% 0px', threshold: 0.01 });
        edition.querySelectorAll('p[data-quip]').forEach(function (p) { quipObs.observe(p); });

        const catFig = edition.querySelector<HTMLElement>('#catFig');
        if (catFig) {
          // develop the cat from B/W to full colour as it's scrolled into reading
          // position — --cat-c (0..1) tracks where the figure sits in the viewport
          let ctick = false;
          const updCat = function () {
            ctick = false;
            const r = catFig.getBoundingClientRect();
            const vh = window.innerHeight || 1;
            const p = Math.max(0, Math.min(1, (vh * 0.85 - r.top) / (vh * 0.5)));
            catFig.style.setProperty('--cat-c', p.toFixed(3));
          };
          const onCat = function () { if (!ctick) { ctick = true; requestAnimationFrame(updCat); } };
          window.addEventListener('scroll', onCat, { passive: true });
          const L = (window as unknown as { __lenis?: { on?: (e: string, cb: () => void) => void } }).__lenis;
          if (L && L.on) L.on('scroll', onCat);
          updCat();
        }

        const penned = edition.querySelector('#penned');
        if (penned) {
          const penObs = new IntersectionObserver(function (es) {
            es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('drawn'); penObs.unobserve(e.target); } });
          }, { threshold: 0.6 });
          penObs.observe(penned);
        }
      } else {
        const cf = edition.querySelector('#catFig'); if (cf) cf.classList.add('resolved');
        const pn = edition.querySelector('#penned'); if (pn) pn.classList.add('drawn');
      }

      /* Stderr figure tilt */
      const catWrap = edition.querySelector<HTMLElement>('#catFig .cat-img-wrap');
      if (catWrap && !REDUCE) {
        window.addEventListener('pointermove', function (ev) {
          const r = catWrap.getBoundingClientRect(); if (!r.width) return;
          const dx = clamp(((ev.clientX - (r.left + r.width / 2)) / window.innerWidth) * 2, -1, 1);
          const dy = clamp(((ev.clientY - (r.top + r.height / 2)) / window.innerHeight) * 2, -1, 1);
          catWrap.style.transform = 'translate(' + (dx * 5).toFixed(1) + 'px,' + (dy * 4).toFixed(1) + 'px) rotate(' + (dx * 1.1).toFixed(2) + 'deg)';
        }, { passive: true });
      }

      /* scroll loop */
      let ticking = false;
      function onScroll() { if (ticking) return; ticking = true; requestAnimationFrame(function () { placeTick(); ticking = false; }); }
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', placeTick);
      placeTick();

      /* page-turn → projects desk: JUMP IN-PAGE to #projects (no navigation) */
      function toProjects() {
        try {
          const lenis = (window as unknown as { __lenis?: { scrollTo: (t: string, o?: unknown) => void } }).__lenis;
          if (lenis) {
            lenis.scrollTo('#projects', { offset: 0 });
          } else {
            document.getElementById('projects')?.scrollIntoView({ behavior: 'smooth' });
          }
        } catch (e) {
          document.getElementById('projects')?.scrollIntoView({ behavior: 'smooth' });
        }
      }
      edition.querySelectorAll<HTMLElement>('.to-projects').forEach(function (a) {
        a.addEventListener('click', function (ev) { ev.preventDefault(); toProjects(); });
      });

    } catch (e) { /* edition engine failed silently */ }
  })();
</script>
