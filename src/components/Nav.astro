  .onav-moon.onav-lit .onav-moon-n { color: var(--olime); }
  .onav-moon.onav-lit:hover .onav-moon-box, .onav-moon.onav-lit:focus-visible .onav-moon-box { background: var(--oink); color: var(--olime); }
  .onav-moon.onav-lit:hover .onav-moon-n { color: var(--olime); }

  .onav-core {
    position: absolute; left: 0; top: 0; transform: translate(-50%, -50%); width: 96px; height: 96px; display: grid; place-items: center;
    background: var(--ored); color: var(--oink); border: 3px solid var(--oink); border-radius: 50%; box-shadow: 6px 6px 0 var(--oblack); cursor: pointer;
