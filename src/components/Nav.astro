  .onav-blast-name { font-family: var(--ofd); font-weight: 700; font-size: clamp(1.7rem, min(8.5vw, 10vh), 7rem); line-height: 0.86; text-transform: uppercase; color: var(--opaper); transition: color 0.2s, transform 0.2s var(--opop); }
