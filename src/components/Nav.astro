  .onav-ci-n { font-family: var(--ofm); font-size: 11px; font-weight: 700; letter-spacing: 0.12em; color: var(--olime); min-width: 2.4ch; }
  .onav-ci-l { font-family: var(--ofm); font-size: 13px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .onav-ci-tag { margin-left: auto; font-family: var(--ofm); font-size: 10px; letter-spacing: 0.12em; color: rgba(247, 245, 241, 0.45); }
  .onav-cmd-item.onav-here .onav-ci-tag { color: var(--olime); }
  .onav-cmd-item.onav-active { background: var(--ored); }
  .onav-cmd-item.onav-active .onav-ci-n, .onav-cmd-item.onav-active .onav-ci-tag { color: var(--opaper); }

