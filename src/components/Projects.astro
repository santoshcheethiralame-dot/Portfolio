---
// Projects — "Living Instruments" section, ported verbatim from
// mockups/projects/01-living-instruments.html. Everything is namespaced with a
// `li-` prefix (classes, CSS vars, @keyframes, ids) so the mockup's generic
// names and its own palette can't collide with the red-themed site.
//
// Styles live in src/styles/global.css (NOT a component <style is:global>):
// Astro's dev server doesn't reliably inject component-level global styles for
// non-hydrated .astro components, which left the section unstyled in dev.
// Cards are built by the inline script at runtime, so the script is:inline.
import Folio from './Folio.astro';
---

<section id="projects" class="li-projects">
  <div class="li-page">
    <Folio page="P.2" desk="THE PROJECTS DESK" tone="ink" />
    <p class="li-kicker">selected work <span class="li-blink">_</span></p>
    <div class="li-title-wrap" id="li-titleWrap">
      <h2 class="li-title">SELECTED <em>WORK</em></h2>
    </div>
    <p class="li-lede">
      Each card is a live <b>2-colour instrument</b> — hover to run the demo, click for the case study.
    </p>

    <div class="li-controls">
      <span class="li-ctrl-label">FILTER:</span>
      <div class="li-toggle-row" id="li-filters" role="group" aria-label="Filter projects">
        <button class="li-toggle" data-filter="all" aria-pressed="true">[ ALL ]</button>
        <button class="li-toggle" data-filter="live" aria-pressed="false">[ LIVE ]</button>
        <button class="li-toggle" data-filter="built" aria-pressed="false">[ BUILT ]</button>
      </div>
      <div class="li-monitor" title="Periodic health checks against live deployments">
        <span class="li-hb" aria-hidden="true"></span>
        <span class="li-pingline" id="li-pingline">booting monitor&hellip;</span>
      </div>
    </div>

    <div class="li-grid" id="li-grid"></div>
  </div>
</section>

