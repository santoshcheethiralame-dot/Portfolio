    var ORDER = ['attest', 'glassbox', 'gradient', 'untangle', 'tessera', 'terracrest', 'orbit', 'pesvcs'];
    PROJECTS = ORDER
      .map(function (k) { for (var i = 0; i < PROJECTS.length; i++) if (PROJECTS[i].key === k) return PROJECTS[i]; return null; })
      .filter(Boolean);
    PROJECTS.forEach(function (p, i) { p.idx = (i + 1 < 10 ? '0' : '') + (i + 1); });

    /* ============================================================ CANVAS ENGINE */
    function base(cv) {
      var o = { cv: cv, ctx: null, w: 0, h: 0, hover: false, visible: true, isCase: false, clk: 0 };
      o.resize = function () {
        var r = cv.getBoundingClientRect(); if (r.width < 1 || r.height < 1) return;
        var dpr = Math.min(2, window.devicePixelRatio || 1);
        cv.width = Math.round(r.width * dpr); cv.height = Math.round(r.height * dpr);
        o.ctx = cv.getContext('2d'); o.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        o.w = r.width; o.h = r.height;
      };
      o.setHover = function (b) { o.hover = b; };
      o.advance = function (dt) { o.clk += dt * (o.hover ? 2.3 : 1) / 1000; };
      return o;
    }

    // ---- ORBIT: retention decaying on an Ebbinghaus curve; review snaps it back ----
    function makeOrbit(cv) {
      var o = base(cv);
      var N = 5, OFF = [0, 0.58, 1.22, 1.86, 2.44], LIME = '#b4ff2e';
      function cl(v, a, b) { return v < a ? a : v > b ? b : v; }
      o.tick = function (now, dt) {
        o.advance(dt);
        var ctx = o.ctx, w = o.w, h = o.h; if (!ctx) return; ctx.clearRect(0, 0, w, h);
        var pad = 16, top = 22, floor = h - 26, H = floor - top, gw = (w - pad * 2) / N, THR = 0.40, i;

        /* the canonical forgetting curve, faint behind everything */
        ctx.strokeStyle = 'rgba(255,255,255,.15)'; ctx.lineWidth = 1.5;
        ctx.beginPath();
        for (i = 0; i <= 60; i++) {
          var f = i / 60, cy = floor - H * Math.exp(-f * 2.6), cx = pad + (w - pad * 2) * f;
          i ? ctx.lineTo(cx, cy) : ctx.moveTo(cx, cy);
        }
        ctx.stroke();

        /* review threshold */
        var ty = floor - H * THR;
        ctx.strokeStyle = 'rgba(255,255,255,.3)'; ctx.lineWidth = 1; ctx.setLineDash([3, 3]);
        ctx.beginPath(); ctx.moveTo(pad, ty); ctx.lineTo(w - pad, ty); ctx.stroke(); ctx.setLineDash([]);
        ctx.font = '600 7px "JetBrains Mono",monospace';
        ctx.textAlign = 'right'; ctx.textBaseline = 'bottom';
        ctx.fillStyle = 'rgba(255,255,255,.42)'; ctx.fillText('REVIEW DUE', w - pad, ty - 2);

        for (i = 0; i < N; i++) {
          var ph = (o.clk * 0.46 + OFF[i]) % 3.0;
          var rising = ph < 0.2;
          var v = cl(rising ? (0.5 + 0.5 * (ph / 0.2)) : Math.exp(-(ph - 0.2) * 0.62), 0.06, 1);
          var bx = pad + i * gw + gw * 0.22, bw = gw * 0.56, bh = H * v;
          ctx.fillStyle = 'rgba(255,255,255,.07)'; ctx.fillRect(bx, top, bw, H);
          ctx.fillStyle = rising ? LIME : (v < THR ? RED : 'rgba(255,255,255,.7)');
          ctx.fillRect(bx, floor - bh, bw, bh);
          ctx.strokeStyle = 'rgba(255,255,255,.5)'; ctx.lineWidth = 1;
          ctx.strokeRect(bx + 0.5, floor - bh + 0.5, bw - 1, bh - 1);
          if (rising) {
            ctx.fillStyle = LIME; ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
            ctx.font = '700 7px "JetBrains Mono",monospace';
            ctx.fillText('REVIEW', bx + bw / 2, floor - bh - 3);
          }
          ctx.fillStyle = 'rgba(255,255,255,.45)'; ctx.textAlign = 'center'; ctx.textBaseline = 'alphabetic';
          ctx.font = '600 7px "JetBrains Mono",monospace';
          ctx.fillText('S' + (i + 1), bx + bw / 2, h - 12);
        }
        ctx.fillStyle = 'rgba(255,255,255,.5)'; ctx.textAlign = 'left';
        ctx.font = '600 8px "JetBrains Mono",monospace';
        ctx.fillText('retention \u00b7 spaced repetition', pad, h - 4);
      };
      return o;
    }
    function makeGlassbox(cv) {
      var o = base(cv); var N = 6, toks = ['the', 'cat', 'sat', 'on', 'a', 'mat'];
      function wt(r, k) { var s = Math.sin(r * 7.13 + k * 3.7 + 1.5) * 0.5 + 0.5; return 0.15 + 0.85 * s; }
      o.tick = function (now, dt) {
        o.advance(dt);
        var ctx = o.ctx, w = o.w, h = o.h; if (!ctx) return; ctx.clearRect(0, 0, w, h);
        var pad = 14, topH = 20, gridTop = pad + topH;
        var avail = Math.min(w - pad * 2, h - gridTop - pad), cell = avail / N;
        var gx = (w - cell * N) / 2, gy = gridTop;
        var qf = o.clk / 0.75, q = Math.floor(qf) % N, within = qf % 1;
        for (var k = 0; k < N; k++) {
          var tx = gx + cell * k, tw = cell, active = (k === q);
          if (active) { ctx.fillStyle = INK; ctx.fillRect(tx + 2, pad - 2, tw - 4, topH - 4); }
          ctx.strokeStyle = 'rgba(255,255,255,.25)'; ctx.lineWidth = 1; ctx.strokeRect(tx + 2.5, pad - 1.5, tw - 5, topH - 5);
          ctx.fillStyle = active ? '#0a0a0a' : 'rgba(255,255,255,.7)';
          ctx.font = '600 9px "JetBrains Mono",monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText(toks[k], tx + tw / 2, pad + topH / 2 - 1);
        }
        for (var r = 0; r < N; r++) {
          for (k = 0; k < N; k++) {
            var cx = gx + cell * k, cy = gy + cell * r, bright = 0;
            if (k <= r) {
              if (r < q) bright = wt(r, k);
              else if (r === q) bright = (k <= within * (r + 1)) ? wt(r, k) : 0;
            }
            if (bright > 0) { ctx.fillStyle = 'rgba(237,28,36,' + (0.12 + 0.8 * bright).toFixed(3) + ')'; ctx.fillRect(cx + 1, cy + 1, cell - 2, cell - 2); }
            ctx.strokeStyle = 'rgba(255,255,255,' + (k <= r ? 0.14 : 0.05) + ')'; ctx.lineWidth = 1; ctx.strokeRect(cx + .5, cy + .5, cell - 1, cell - 1);
          }
        }
        ctx.strokeStyle = 'rgba(255,255,255,.55)'; ctx.lineWidth = 1.5;
        ctx.strokeRect(gx + .5, gy + cell * q + .5, cell * N - 1, cell - 1);
      };
      return o;
    }

    // ---- GRADIENT: a real 2-layer MLP (2 -> 16 tanh -> 1 sigmoid) learning
    //      two-moons by actual backprop, live. The decision boundary forms as
    //      the net trains; loss/acc are the real numbers. No faked frames.
    function makeGradient(cv) {
      var o = base(cv);
      var H = 16, lr = 0.35, N = 120, maxEpoch = 360;
      var DX0 = -1.5, DX1 = 1.5, DY0 = -1.3, DY1 = 1.3;
      var data, W1, b1, W2, b2, epoch, settle, run = 0, lossv = 1, accv = 0;
      function rnd() { return (Math.random() * 2 - 1) * 0.8; }
      function genMoons() {
        data = [];
        for (var i = 0; i < N; i++) {
          var c = i % 2, t = Math.PI * Math.random(), nx = (Math.random() - 0.5) * 0.18, ny = (Math.random() - 0.5) * 0.18, x, y;
          if (c === 0) { x = Math.cos(t); y = Math.sin(t); } else { x = 1 - Math.cos(t); y = -Math.sin(t) - 0.2; }
          data.push({ x: (x - 0.5) * 0.9 + nx, y: (y + 0.1) * 0.9 + ny, c: c });
        }
      }
      function reset() {
        genMoons();
        W1 = []; b1 = []; W2 = [];
        for (var j = 0; j < H; j++) { W1.push([rnd(), rnd()]); b1.push(0); W2.push(rnd()); }
        b2 = 0; epoch = 0; settle = 0; lossv = 1; accv = 0; run++;
      }
      reset();
      function fwd(x, y) {
        var a1 = new Array(H), z;
        for (var j = 0; j < H; j++) { z = W1[j][0] * x + W1[j][1] * y + b1[j]; a1[j] = Math.tanh(z); }
        var z2 = b2; for (j = 0; j < H; j++) z2 += W2[j] * a1[j];
        return { a1: a1, p: 1 / (1 + Math.exp(-z2)) };
      }
      function trainEpoch() {
        var gW1 = [], gb1 = new Array(H).fill(0), gW2 = new Array(H).fill(0), gb2 = 0, L = 0, ok = 0, j;
        for (j = 0; j < H; j++) gW1.push([0, 0]);
        for (var i = 0; i < N; i++) {
          var d = data[i], f = fwd(d.x, d.y), p = f.p, y = d.c;
          L += -(y * Math.log(p + 1e-7) + (1 - y) * Math.log(1 - p + 1e-7));
          if ((p > 0.5 ? 1 : 0) === y) ok++;
          var dz2 = p - y; gb2 += dz2;
          for (j = 0; j < H; j++) {
            gW2[j] += dz2 * f.a1[j];
            var dz1 = dz2 * W2[j] * (1 - f.a1[j] * f.a1[j]);
