          '<canvas class="li-demo"></canvas>' +
          '<div class="li-scan"></div>' +
          '<div class="li-mono"><i>' + p.mono + '</i></div>' +
          badge +
          '<div class="li-idx">' + p.idx + '</div>' +
        '</div>' +
        '<div class="li-card-body">' +
          '<div class="li-name-row"><span class="li-pname" data-decode="' + p.name + '">' + p.name + '</span>' +
            '<span class="li-plabel" data-decode="' + p.label + '">' + p.label + '</span></div>' +
          '<p class="li-blurb">' + p.blurb + '</p>' +
          '<div class="li-stack">' + p.stack.map(function (t) { return '<span>' + t + '</span>'; }).join('') + '</div>' +
          '<div class="li-stats">' + p.stats.map(statHTML).join('') + '</div>' +
          '<button class="li-view" type="button">VIEW CASE STUDY <span class="li-arr">&rarr;</span></button>' +
        '</div>';
      grid.appendChild(card);
      cardByKey[p.key] = card;

      var cv = card.querySelector('canvas.li-demo');
      var r = RENDER[p.key](cv); r.resize();
      cv._r = r; renderers.push(r);

      var head = card.querySelector('.li-card-head');
      card.addEventListener('mouseenter', function () { r.setHover(true); head.classList.add('li-sweep'); });
      card.addEventListener('mouseleave', function () { r.setHover(false); });
      head.addEventListener('animationend', function () { head.classList.remove('li-sweep'); });

      function open() { openCase(p); }
      head.addEventListener('click', open);
      card.querySelector('.li-view').addEventListener('click', open);

      if (REDUCED) staticFrame(r, p.key);
    });

    startLoop();

    /* ============================================================ REVEAL */
    function countUp(el) {
      var target = parseFloat(el.dataset.target), dec = parseInt(el.dataset.decimals, 10) || 0, dur = 1000, t0 = performance.now();
      function fmt(v) { return dec ? v.toFixed(dec) : Math.round(v).toLocaleString(); }
      if (REDUCED) { el.textContent = fmt(target); return; }
      (function step(now) {
        var p = Math.min(1, (now - t0) / dur), e = 1 - Math.pow(1 - p, 3);
        el.textContent = fmt(target * e);
        if (p < 1) requestAnimationFrame(step); else el.textContent = fmt(target);
      })(t0);
    }

    var GLYPHS = 'ABCDEFGHKLMNPRSTUVXYZ0123456789/<>_#';
    function decode(el) {
      var fin = el.dataset.decode || el.textContent, dur = 620, t0 = performance.now();
      if (REDUCED) { el.textContent = fin; return; }
      (function step(now) {
        var p = Math.min(1, (now - t0) / dur), reveal = Math.floor(p * fin.length), out = '';
        for (var i = 0; i < fin.length; i++) {
          if (i < reveal || fin[i] === ' ') out += fin[i];
          else out += GLYPHS[(Math.random() * GLYPHS.length) | 0];
        }
        el.textContent = out;
        if (p < 1) requestAnimationFrame(step); else el.textContent = fin;
      })(t0);
    }

    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        var card = en.target, r = card.querySelector('canvas.li-demo')._r;
        r.visible = en.isIntersecting;
        if (en.isIntersecting && !card._revealed) {
          card._revealed = true;
          card.querySelectorAll('.li-val').forEach(countUp);
          card.querySelectorAll('[data-decode]').forEach(decode);
        }
      });
    }, { threshold: 0.18 });
    Object.keys(cardByKey).forEach(function (k) { io.observe(cardByKey[k]); });

    /* ============================================================ FILTER (FLIP) */
    var filters = Array.prototype.slice.call(document.querySelectorAll('#li-filters .li-toggle'));
    var curFilter = 'all';
    filters.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var f = btn.dataset.filter; if (f === curFilter) return;
        filters.forEach(function (b) { b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'); });
        applyFilter(f);
      });
    });
    /* Two phases: leavers fade/scale out IN PLACE first (display:none on the
       same frame used to kill the .li-is-out fade entirely), then the grid
       collapses — survivors FLIP, enterers fade in from staged-hidden. */
    var filterSeq = 0;
    function applyFilter(f) {
      curFilter = f;
      var seq = ++filterSeq;
      var cards = PROJECTS.map(function (p) { return cardByKey[p.key]; });
      var match = function (c) { return f === 'all' || c.dataset.status === f; };
      if (REDUCED) {
        cards.forEach(function (c) {
          c.style.display = match(c) ? '' : 'none';
          c.classList.toggle('li-is-out', !match(c));
        });
        return;
      }
      var leaving = 0;
      cards.forEach(function (c) {
        if (!match(c) && c.style.display !== 'none') { c.classList.add('li-is-out'); leaving++; }
      });
      setTimeout(function () {
        if (seq !== filterSeq) return; /* superseded by a faster click */
        var first = {}; cards.forEach(function (c) { first[c.dataset.key] = c.getBoundingClientRect(); });
        var entering = [];
        cards.forEach(function (c) {
          var m = match(c);
          if (m && c.style.display === 'none') { c.classList.add('li-is-out'); entering.push(c); }
          c.style.display = m ? '' : 'none';
        });
        cards.forEach(function (c) {
          if (c.style.display === 'none') return;
          var fr = first[c.dataset.key];
          if (!fr || fr.width === 0) return; /* enterer — no FLIP source rect */
          var lr = c.getBoundingClientRect();
          var dx = fr.left - lr.left, dy = fr.top - lr.top;
          if (!dx && !dy) return;
          c.style.transition = 'none';
          c.style.transform = 'translate(' + dx + 'px,' + dy + 'px)';
        });
        var flipped = false;
        function finishFlip() {
          if (flipped || seq !== filterSeq) return;
          flipped = true;
          cards.forEach(function (c) {
            if (c.style.display === 'none') return;
            c.style.transition = 'transform .5s cubic-bezier(.2,.9,.2,1)';
            c.style.transform = '';
          });
          entering.forEach(function (c) { c.classList.remove('li-is-out'); });
          setTimeout(function () {
            if (seq !== filterSeq) return;
            cards.forEach(function (c) { c.style.transition = ''; }); /* hover timing back to the stylesheet */
          }, 540);
        }
        requestAnimationFrame(function () { requestAnimationFrame(finishFlip); });
        setTimeout(finishFlip, 250); /* rAF can stall in background tabs */
      }, leaving ? 200 : 0);
    }

    /* ============================================================ SCROLL UI */
    var titleWrap = document.getElementById('li-titleWrap');
    var lastScroll = window.scrollY, vel = 0, squash = 0;
    window.addEventListener('scroll', function () {
      var y = window.scrollY; vel = y - lastScroll; lastScroll = y;
    }, { passive: true });

    function uiFrame() {
      if (!sectionLive()) { uiOn = false; return; }
      document.documentElement.style.setProperty('--li-hatch', (lastScroll * 0.45 % 200) + 'px');
      var vc = window.innerHeight * 0.5;
      PROJECTS.forEach(function (p) {
        var card = cardByKey[p.key]; if (card.style.display === 'none') return;
        var rc = card.getBoundingClientRect(), cc = rc.top + rc.height * 0.5;
        var d = Math.min(1, Math.abs(cc - vc) / (window.innerHeight * 0.7));
        card.querySelector('.li-idx').style.setProperty('--g', (1 - d).toFixed(3));
      });
      squash += (Math.max(-60, Math.min(60, vel)) - squash) * 0.25; vel *= 0.8;
      var k = squash * 0.0016;
      if (titleWrap) titleWrap.style.transform = 'scaleY(' + (1 - k).toFixed(4) + ') scaleX(' + (1 + k * 0.7).toFixed(4) + ')';
      requestAnimationFrame(uiFrame);
    }
    function startUi() {
      if (!REDUCED && !uiOn && sectionLive()) { uiOn = true; requestAnimationFrame(uiFrame); }
    }
    startUi();
    if (REDUCED) {
      document.documentElement.style.setProperty('--li-hatch', '0px');
      PROJECTS.forEach(function (p) { cardByKey[p.key].querySelector('.li-idx').style.setProperty('--g', '0.6'); });
    }

    /* both loops wake when the section scrolls back into view */
    if (typeof IntersectionObserver !== 'undefined') {
      var sectionEl = document.querySelector('.li-projects');
      if (sectionEl) {
        new IntersectionObserver(function (es) {
          es.forEach(function (en) { sectionVisible = en.isIntersecting; });
          startLoop(); startUi();
        }, { rootMargin: '80px 0px' }).observe(sectionEl);
      }
    }

    /* ============================================================ LIVE MONITOR
       REAL reachability checks against the live deployments. A no-cors GET is
       opaque (status unreadable) but resolving at all means the host answered,
       and the round-trip time is genuine. */
    var pingline = document.getElementById('li-pingline');
    var liveProjects = PROJECTS.filter(function (p) { return p.status === 'live'; });
    var pIdx = 0;
    function pingNext() {
      if (!liveProjects.length || !pingline || typeof fetch !== 'function') return;
      if (document.hidden) { setTimeout(pingNext, 8000); return; }
      var p = liveProjects[pIdx % liveProjects.length]; pIdx++;
      pingline.innerHTML = '&#9656; ping <b>' + p.host + '</b> &hellip;';
      var t0 = performance.now();
      var ctl = typeof AbortController !== 'undefined' ? new AbortController() : null;
      var tmo = setTimeout(function () { if (ctl) ctl.abort(); }, 6000);
      fetch('https://' + p.host, { method: 'GET', mode: 'no-cors', cache: 'no-store', signal: ctl ? ctl.signal : undefined })
        .then(function () {
          var ms = Math.max(1, Math.round(performance.now() - t0));
          pingline.innerHTML = '&#9656; <b>' + p.host + '</b> &rarr; <span class="li-ok">reachable</span> ' + ms + 'ms';
          var badge = cardByKey[p.key].querySelector('.li-badge.li-live');
          if (badge) { badge.classList.add('li-pinged'); setTimeout(function () { badge.classList.remove('li-pinged'); }, 520); }
        })
        .catch(function () {
          pingline.innerHTML = '&#9656; <b>' + p.host + '</b> &rarr; no response';
        })
        .then(function () { clearTimeout(tmo); setTimeout(pingNext, 9000); });
    }
    setTimeout(pingNext, 900);

    /* ============================================================ CASE STUDY */
    var activePanel = null, caseRenderer = null;

    function buildPanel(p) {
      var panel = document.createElement('section');
      panel.className = 'li-cs-panel'; panel.dataset.key = p.key;
      var srcLink = '<a class="li-cs-link li-ghost" href="' + p.github + '" target="_blank" rel="noopener">VIEW SOURCE</a>';
      var links = (p.host
        ? '<a class="li-cs-link li-primary" href="https://' + p.host + '" target="_blank" rel="noopener">VISIT LIVE &rarr;</a>' + srcLink
        : srcLink);
      var metaRows = Object.keys(p.meta).map(function (kk) { return '<dt>' + kk + '</dt><dd>' + p.meta[kk] + '</dd>'; }).join('');
      panel.innerHTML =
        '<div class="li-cs-head">' +
          '<canvas class="li-demo"></canvas>' +
          '<div class="li-cs-mono"><i>' + p.mono + '</i></div>' +
          '<button class="li-cs-close" type="button">CLOSE &times; ESC</button>' +
        '</div>' +
        '<div class="li-cs-scroll" data-lenis-prevent><div class="li-cs-body">' +
          '<div class="li-cs-eyebrow">' + p.label + '</div>' +
          '<h2 class="li-cs-title">' + p.name + '</h2>' +
          '<p class="li-cs-tag">' + p.tagline + '</p>' +
          '<div class="li-cs-grid">' +
            '<div>' +
              '<div class="li-cs-section-h">Overview</div>' +
              '<p style="font-size:14px;line-height:1.6;color:#222;margin:0 0 26px;">' + p.overview + '</p>' +
              '<div class="li-cs-section-h">Highlights</div>' +
              '<ul class="li-cs-list">' + p.highlights.map(function (x) { return '<li>' + x + '</li>'; }).join('') + '</ul>' +
            '</div>' +
            '<aside>' +
              '<div class="li-cs-section-h">Stack</div>' +
              '<div class="li-stack" style="margin-bottom:22px">' + p.stack.map(function (t) { return '<span>' + t + '</span>'; }).join('') + '</div>' +
              '<div class="li-cs-meta"><dl style="margin:0">' + metaRows + '</dl></div>' +
              '<div class="li-cs-links">' + links + '</div>' +
            '</aside>' +
          '</div>' +
        '</div></div>';
      return panel;
    }

    function openCase(p) {
      if (activePanel) return;
      var card = cardByKey[p.key], rect = card.getBoundingClientRect();
      var panel = buildPanel(p); document.body.appendChild(panel);
      panel.style.left = rect.left + 'px'; panel.style.top = rect.top + 'px';
      panel.style.width = rect.width + 'px'; panel.style.height = rect.height + 'px';
      var cv = panel.querySelector('canvas.li-demo');
      var r = RENDER[p.key](cv); r.isCase = true; r.resize(); cv._r = r; caseRenderer = r; renderers.push(r);
      activePanel = panel; overlayOpen = true;
      card.classList.add('li-cs-source'); // hide the real card while the panel stands in
      startLoop(); // the case renderer needs ticks even if the section gate slept
      document.body.classList.add('li-cs-open');
      // freeze Lenis while the panel is up — otherwise it owns the wheel and
      // the panel's own scroll area is unreachable by mouse
      if (window.__lenis && window.__lenis.stop) window.__lenis.stop();

      panel.getBoundingClientRect();
      requestAnimationFrame(function () { panel.classList.add('li-cs-expand'); });

      panel.addEventListener('transitionend', function (e) {
        if (e.propertyName === 'width') { r.resize(); if (REDUCED) staticFrame(r, p.key); }
      });
      if (REDUCED) { panel.style.transition = 'none'; panel.classList.add('li-cs-expand'); r.resize(); staticFrame(r, p.key); }

      panel.querySelector('.li-cs-close').addEventListener('click', closeCase);
    }

    function closeCase() {
      if (!activePanel) return;
      var panel = activePanel, key = panel.dataset.key, card = cardByKey[key];
      var rect = card.getBoundingClientRect();
      panel.style.left = rect.left + 'px'; panel.style.top = rect.top + 'px';
      panel.style.width = rect.width + 'px'; panel.style.height = rect.height + 'px';
      panel.classList.remove('li-cs-expand');
      panel.classList.add('li-cs-closing'); // collapse + fade so removal is seamless
      var done = function () {
        renderers = renderers.filter(function (x) { return x !== caseRenderer; });
        caseRenderer = null; panel.remove(); activePanel = null;
        if (card) card.classList.remove('li-cs-source'); // reveal the real card
        overlayOpen = false; document.body.classList.remove('li-cs-open');
        if (window.__lenis && window.__lenis.start) window.__lenis.start();
      };
      if (REDUCED) { done(); return; }
      var fired = false;
      panel.addEventListener('transitionend', function (e) { if (e.propertyName === 'width' && !fired) { fired = true; done(); } });
      setTimeout(function () { if (!fired) { fired = true; done(); } }, 620);
    }

    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeCase(); });

    /* ============================================================ RESIZE */
    var rz = null;
    window.addEventListener('resize', function () {
      if (rz) clearTimeout(rz);
      rz = setTimeout(function () {
        renderers.forEach(function (r) {
          r.resize();
          if (REDUCED) { var host = r.cv.closest('[data-key]'); staticFrame(r, host ? host.dataset.key : 'orbit'); }
        });
      }, 140);
    });
  })();
</script>
