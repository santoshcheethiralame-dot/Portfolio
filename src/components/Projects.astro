        { n: 'CANNOT DEFEND', c: '#ed1c24',               amp: 0.16, d: 1.4 },
        { n: 'TEACH',         c: '#b4ff2e',               amp: 0.60, d: 1.8 },
        { n: 'RE-ASK \u2713',     c: 'rgba(255,255,255,.95)', amp: 1.00, d: 1.6 }
      ];
